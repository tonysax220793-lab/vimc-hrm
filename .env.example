# Sao chép file này thành .env.local và điền giá trị thật (KHÔNG commit .env.local)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_AUTH_EMAIL_DOMAIN=vimc.local
# Google Maps Geocoding — để hiển thị địa chỉ từ toạ độ GPS khi chấm công.
# Tạo key tại console.cloud.google.com, bật "Geocoding API", hạn chế theo HTTP referrer.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
